# Set to true to use seed data instead of hitting real APIs
USE_MOCK_DATA=true
MERCHANT_ID=zapbold-001

# LLM Provider — "anthropic" (default) or "groq" (free tier)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (free tier — use instead of Anthropic)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Shopify
SHOPIFY_SHOP_URL=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# Shiprocket
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-password

# Meta Ads
META_APP_ID=...
META_APP_SECRET=...
META_ACCESS_TOKEN=...
META_AD_ACCOUNT_ID=act_...

# Database (SQLite default; swap to PostgreSQL for production)
DATABASE_URL=sqlite:///d2c.db

# How fresh data must be before a live re-sync is triggered (in hours)
MAX_DATA_AGE_HOURS=1

# Agent thresholds
NDR_THRESHOLD=0.15
ROAS_THRESHOLD=1.5
MIN_SHIPMENTS_FOR_CONFIDENCE=30
